# Casper network
CASPER_NODE_RPC_URL=https://node.testnet.casper.network/rpc
CASPER_NETWORK_NAME=casper-test
AUTARCA_CONTRACT_HASH=hash-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Agent identity (bound to CSPR.click Agent Skill)
AGENT_PRIVATE_KEY_PATH=./keys/agent_secret_key.pem
AGENT_PUBLIC_KEY_HEX=

# Casper MCP Server
MCP_SERVER_URL=http://localhost:4000

# x402 micropayments
X402_FACILITATOR_URL=https://x402.casper.network
X402_WALLET_ADDRESS=

# Off-chain RWA valuation data provider (example, pay-per-call via x402)
RWA_DATA_PROVIDER_URL=https://api.example-rwa-data.com/v1/valuation

# LLM decision agent
# Works with OpenAI, Groq, OpenRouter, or a local Ollama server (any
# OpenAI-compatible API). Leave LLM_API_KEY empty to use the built-in
# deterministic rule-based fallback (no LLM needed at all).
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile

# Loop interval (ms)
AGENT_POLL_INTERVAL_MS=60000
